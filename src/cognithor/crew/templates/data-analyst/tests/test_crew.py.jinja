"""Smoke test for {{ project_name }}.DataAnalystCrew.

Uses a mock Planner so the test never hits Ollama / a network — runs in
< 1 s on any CI. Swap in a real Planner in integration tests.
"""

from __future__ import annotations

from unittest.mock import AsyncMock, MagicMock

import pytest

from {{ project_name }}.crew import DataAnalystCrew


@pytest.mark.asyncio
async def test_crew_kickoff_with_mock_planner(monkeypatch):
    from cognithor.core.observer import ResponseEnvelope

    mock_planner = MagicMock()
    mock_planner.formulate_response = AsyncMock(
        return_value=ResponseEnvelope(content="MOCK_OUTPUT", directive=None),
    )
    mock_registry = MagicMock()
    # The analyst agent declares `tools=["python_sandbox"]` — register it in the
    # mock so `resolve_tools` passes. Real projects wire the actual sandbox via
    # the MCP tool registry at runtime.
    _sandbox = MagicMock()
    _sandbox.name = "python_sandbox"
    mock_registry.get_tools_for_role.return_value = [_sandbox]

    monkeypatch.setattr(
        "cognithor.crew.runtime.get_default_tool_registry",
        lambda: mock_registry,
    )
    monkeypatch.setattr(
        "cognithor.crew.runtime.get_default_planner",
        lambda: mock_planner,
    )

    crew = DataAnalystCrew().assemble()
    result = await crew.kickoff_async(inputs={"csv_path": "data.csv"})
    assert result.raw == "MOCK_OUTPUT"
    assert len(result.tasks_output) == 2
