"""Entry point for the {{ project_name }} crew.

Run via::

    {{ project_name }}                    # via project.scripts
    python -m {{ project_name }}.main     # module form

Or embed in Python code::

    from {{ project_name }}.crew import ResearchCrew

    result = ResearchCrew().assemble().kickoff(inputs={"topic": "Quantum ML"})
    print(result.raw)
"""

from __future__ import annotations

import asyncio
import sys

from {{ project_name }}.crew import ResearchCrew


def main() -> int:
    """CLI entry — accept ``topic`` as the first arg or prompt for it."""
    if len(sys.argv) > 1:
        topic = " ".join(sys.argv[1:])
    else:
        topic = input("Topic: ").strip()
    if not topic:
        print("error: no topic given", file=sys.stderr)
        return 2

    crew = ResearchCrew().assemble()
    result = asyncio.run(crew.kickoff_async(inputs={"topic": topic}))
    print(result.raw)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
