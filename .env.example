# ============================================================================
# Cognithor · Agent OS — Environment Variables (Optional)
# ============================================================================
# Override config.yaml values. Useful for Docker/Deployment.
# Copy to .env and edit. Loaded by systemd EnvironmentFile.
# ============================================================================

# --- Ollama (Local) ---
# COGNITHOR_OLLAMA_BASE_URL=http://localhost:11434

# --- User ---
# COGNITHOR_OWNER_NAME=Max

# --- LLM Backend ---
# COGNITHOR_LLM_BACKEND_TYPE=ollama
# Supported: ollama | openai | anthropic | gemini | groq | deepseek |
#            mistral | together | openrouter | xai | cerebras | github |
#            bedrock | huggingface | moonshot

# --- API Keys (set the one for your chosen backend) ---
# COGNITHOR_OPENAI_API_KEY=sk-...
# COGNITHOR_OPENAI_BASE_URL=https://api.openai.com/v1
# COGNITHOR_ANTHROPIC_API_KEY=sk-ant-...
# COGNITHOR_ANTHROPIC_MAX_TOKENS=4096
# COGNITHOR_GEMINI_API_KEY=AIza...
# COGNITHOR_GROQ_API_KEY=gsk_...
# COGNITHOR_DEEPSEEK_API_KEY=sk-...
# COGNITHOR_MISTRAL_API_KEY=...
# COGNITHOR_TOGETHER_API_KEY=...
# COGNITHOR_OPENROUTER_API_KEY=sk-or-...
# COGNITHOR_XAI_API_KEY=xai-...
# COGNITHOR_CEREBRAS_API_KEY=csk-...
# COGNITHOR_GITHUB_MODELS_TOKEN=ghp_...
# COGNITHOR_BEDROCK_REGION=us-east-1
# COGNITHOR_HUGGINGFACE_API_KEY=hf_...
# COGNITHOR_MOONSHOT_API_KEY=sk-...

# --- Logging ---
# COGNITHOR_LOGGING_LEVEL=INFO

# --- Language ---
# COGNITHOR_LANGUAGE=de

# --- Models ---
# COGNITHOR_MODELS_PLANNER=qwen3:32b
# COGNITHOR_MODELS_EXECUTOR=qwen3:8b
# COGNITHOR_MODELS_CODER=qwen3:32b
# COGNITHOR_MODELS_EMBEDDING=nomic-embed-text

# --- LM Studio (Alternative zu Ollama) ---
# COGNITHOR_LMSTUDIO_BASE_URL=http://localhost:1234
# COGNITHOR_LMSTUDIO_API_KEY=

# --- Channels ---
# COGNITHOR_CHANNELS_CLI_ENABLED=true
# COGNITHOR_CHANNELS_WEBUI_ENABLED=true
# COGNITHOR_CHANNELS_WEBUI_PORT=8080
# COGNITHOR_CHANNELS_VOICE_ENABLED=false

# --- Telegram ---
# COGNITHOR_CHANNELS_TELEGRAM_ENABLED=true
# COGNITHOR_TELEGRAM_TOKEN=7123456789:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
# COGNITHOR_TELEGRAM_ALLOWED_USERS=123456789,987654321
# COGNITHOR_CHANNELS_TELEGRAM_USE_WEBHOOK=false
# COGNITHOR_CHANNELS_TELEGRAM_WEBHOOK_URL=
# COGNITHOR_CHANNELS_TELEGRAM_WEBHOOK_PORT=8443

# --- Discord ---
# COGNITHOR_CHANNELS_DISCORD_ENABLED=true
# DISCORD_TOKEN=your-discord-bot-token
# COGNITHOR_CHANNELS_DISCORD_CHANNEL_ID=

# --- Slack ---
# COGNITHOR_CHANNELS_SLACK_ENABLED=true
# SLACK_BOT_TOKEN=xoxb-your-slack-token
# COGNITHOR_CHANNELS_SLACK_DEFAULT_CHANNEL=general

# --- Matrix ---
# COGNITHOR_CHANNELS_MATRIX_ENABLED=true
# MATRIX_ACCESS_TOKEN=your-matrix-token
# COGNITHOR_CHANNELS_MATRIX_HOMESERVER=https://matrix.org
# COGNITHOR_CHANNELS_MATRIX_USER_ID=@bot:matrix.org

# --- Microsoft Teams ---
# COGNITHOR_CHANNELS_TEAMS_ENABLED=true
# TEAMS_APP_ID=your-teams-app-id
# TEAMS_APP_PASSWORD=your-teams-app-password

# --- WhatsApp ---
# COGNITHOR_CHANNELS_WHATSAPP_ENABLED=true
# WHATSAPP_TOKEN=your-whatsapp-token
# COGNITHOR_CHANNELS_WHATSAPP_PHONE_NUMBER_ID=
# COGNITHOR_CHANNELS_WHATSAPP_WEBHOOK_PORT=8444
# COGNITHOR_CHANNELS_WHATSAPP_VERIFY_TOKEN=
# COGNITHOR_CHANNELS_WHATSAPP_ALLOWED_NUMBERS=

# --- Signal ---
# COGNITHOR_CHANNELS_SIGNAL_ENABLED=true
# SIGNAL_PHONE_NUMBER=+49123456789
# COGNITHOR_CHANNELS_SIGNAL_DEFAULT_USER=

# --- Google Chat ---
# COGNITHOR_CHANNELS_GOOGLE_CHAT_ENABLED=true
# COGNITHOR_CHANNELS_GOOGLE_CHAT_CREDENTIALS_PATH=
# COGNITHOR_CHANNELS_GOOGLE_CHAT_ALLOWED_SPACES=

# --- Mattermost ---
# COGNITHOR_CHANNELS_MATTERMOST_ENABLED=true
# COGNITHOR_CHANNELS_MATTERMOST_URL=https://mattermost.example.com
# COGNITHOR_CHANNELS_MATTERMOST_TOKEN=your-token
# COGNITHOR_CHANNELS_MATTERMOST_CHANNEL=town-square

# --- Feishu/Lark ---
# COGNITHOR_CHANNELS_FEISHU_ENABLED=true
# COGNITHOR_CHANNELS_FEISHU_APP_ID=
# COGNITHOR_CHANNELS_FEISHU_APP_SECRET=

# --- IRC ---
# COGNITHOR_CHANNELS_IRC_ENABLED=true
# COGNITHOR_CHANNELS_IRC_SERVER=irc.libera.chat
# COGNITHOR_CHANNELS_IRC_PORT=6697
# COGNITHOR_CHANNELS_IRC_NICK=cognithor
# COGNITHOR_CHANNELS_IRC_CHANNELS=#channel1,#channel2

# --- Twitch ---
# COGNITHOR_CHANNELS_TWITCH_ENABLED=true
# COGNITHOR_CHANNELS_TWITCH_TOKEN=oauth:your-token
# COGNITHOR_CHANNELS_TWITCH_CHANNEL=yourchannel

# --- iMessage (macOS only) ---
# COGNITHOR_CHANNELS_IMESSAGE_ENABLED=true

# --- Web Search Providers ---
# COGNITHOR_WEB_SEARXNG_URL=http://localhost:8888
# COGNITHOR_WEB_BRAVE_API_KEY=BSA...
# COGNITHOR_WEB_GOOGLE_CSE_API_KEY=AIza...
# COGNITHOR_WEB_GOOGLE_CSE_CX=
# COGNITHOR_WEB_JINA_API_KEY=jina_...

# --- Personality ---
# COGNITHOR_PERSONALITY_WARMTH=0.7
# COGNITHOR_PERSONALITY_HUMOR=0.3

# --- Credential-Store Password ---
# If not set, a random one is generated and stored in ~/.cognithor/.credential_key
# COGNITHOR_CREDENTIAL_PASSPHRASE=your-secure-password-here

# --- Home Directory (Default: ~/.cognithor) ---
# COGNITHOR_HOME=/opt/cognithor/data

# ============================================================================
# Server Deployment (Docker / Bare-Metal)
# ============================================================================

# --- Control Center API ---
# COGNITHOR_API_HOST=0.0.0.0
# COGNITHOR_API_TOKEN=your-secure-api-token-here
# COGNITHOR_API_CORS_ORIGINS=https://jarvis.example.com

# --- WebUI Channel (standalone via uvicorn --factory) ---
# COGNITHOR_WEBUI_HOST=0.0.0.0
# COGNITHOR_WEBUI_CORS_ORIGINS=https://jarvis.example.com

# --- TLS ---
# COGNITHOR_SSL_CERTFILE=/etc/letsencrypt/live/jarvis.example.com/fullchain.pem
# COGNITHOR_SSL_KEYFILE=/etc/letsencrypt/live/jarvis.example.com/privkey.pem

# --- PostgreSQL (optional, für pgvector) ---
# COGNITHOR_POSTGRES_HOST=localhost
# COGNITHOR_POSTGRES_PORT=5432
# COGNITHOR_POSTGRES_DB=cognithor
# COGNITHOR_POSTGRES_USER=cognithor
# COGNITHOR_POSTGRES_PASSWORD=change-me-in-production
